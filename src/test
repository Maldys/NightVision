#!/usr/bin/env python3
import time
import numpy as np
import cv2
from picamera2 import Picamera2, Preview, MappedArray

W, H = 640, 480  # testovací náhled

def cb(request):
    try:
        # mapuj PŘÍMO zobrazovaný buffer "main"
        with MappedArray(request, "main") as m:
            frame = m.array  # HxWxC, typicky RGB888 -> C=3
            h, w = frame.shape[:2]

            # jednou za ~30 snímků celý obraz zčerni (blik test)
            if not hasattr(cb, "i"):
                cb.i = 0
            cb.i = (cb.i + 1) % 30
            if cb.i == 1:
                frame[:] = 0
                return

            # černý čtverec přesně doprostřed (60x60)
            cx, cy, sz = w // 2, h // 2, 60
            x1 = max(0, cx - sz // 2); x2 = min(w, cx + sz // 2)
            y1 = max(0, cy - sz // 2); y2 = min(h, cy + sz // 2)
            frame[y1:y2, x1:x2, :] = 0

    except Exception as e:
        print("callback error:", e)

def main():
    picam = Picamera2()
    cfg = picam.create_preview_configuration(
        main={"size": (W, H), "format": "RGB888"},
        display="main",  # DŮLEŽITÉ: preview zobrazuje přímo "main"
    )
    picam.configure(cfg)

    # nastav callback PŘED startem
    picam.post_callback = cb

    picam.start_preview(Preview.DRM)
    picam.start()

    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        pass
    finally:
        try: picam.stop_preview()
        except: pass
        try: picam.stop()
        except: pass
        try: picam.close()
        except: pass

if __name__ == "__main__":
    main()